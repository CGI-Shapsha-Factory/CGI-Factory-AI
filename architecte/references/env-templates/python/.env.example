# Copier en .env et remplir : NE PAS committer .env
# Chaque valeur ci-dessous est un PLACEHOLDER à remplacer par la vraie valeur.

# Environnement applicatif : development | staging | production
APP_ENV=development
# URL de connexion à la base (placeholder : remplacer par la vraie chaîne)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# Clé secrète de l'application (placeholder : générer une valeur forte et unique)
SECRET_KEY=change-me
# Niveau de log : DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
