# Copier en .env et remplir : NE PAS committer .env
# Chaque valeur ci-dessous est un PLACEHOLDER à remplacer.
# Chargé via godotenv (github.com/joho/godotenv).

# Environnement applicatif : development | staging | production
APP_ENV=development
# Port d'écoute du serveur HTTP
PORT=8080
# URL de connexion à la base (placeholder)
DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable
# Clé d'API d'un service externe (placeholder)
API_KEY=your-api-key-here
