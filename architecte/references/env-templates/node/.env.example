# Copier en .env et remplir : NE PAS committer .env
# Chaque valeur ci-dessous est un PLACEHOLDER à remplacer.

# Environnement Node : development | production | test
NODE_ENV=development
# Port d'écoute du serveur Express
PORT=3000
# URL de connexion à la base (placeholder)
DATABASE_URL=postgres://user:password@localhost:5432/dbname
# Secret de signature des JWT (placeholder : générer une valeur forte)
JWT_SECRET=change-me
# Niveau de log : debug | info | warn | error
LOG_LEVEL=info
