# Copier en .env et remplir — NE PAS committer .env
# ATTENTION : toute variable préfixée VITE_ est INJECTÉE DANS LE BUNDLE CLIENT
# = PUBLIQUE (lisible par n'importe quel visiteur). N'y mettez JAMAIS de secret.
# Les secrets restent côté serveur (API, proxy, gestionnaire de secrets).

# URL publique de l'API consommée par le front
VITE_API_URL=https://api.example.com
# Titre affiché de l'application
VITE_APP_TITLE=Mon App
