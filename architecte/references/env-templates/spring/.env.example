# Copier en .env et remplir : NE PAS committer .env
# Variables injectées dans application.yml via la syntaxe ${VAR}.

# URL JDBC de la base (placeholder)
DB_URL=jdbc:postgresql://localhost:5432/app
# Utilisateur de la base
DB_USER=app
# Mot de passe de la base (placeholder : générer une valeur forte)
DB_PASSWORD=change-me
# Port d'écoute du serveur
PORT=8080
