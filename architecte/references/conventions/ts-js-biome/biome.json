{
  "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
  "comment": "Conventions TS/JS — Biome (formateur + linter en un seul outil, ecrit en Rust). Option par defaut 2026. Copie dans conventions/ du projet si TS/JS dans la stack.",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
